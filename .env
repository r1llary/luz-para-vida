# Appwrite – Expo injeta variáveis EXPO_PUBLIC_* no bundle (reinicie o Metro após alterar)
# Console: Project Settings (endpoint / project id) · Database → Tables (database id / collection ids)

EXPO_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=69c45ffe000d38450eff
EXPO_PUBLIC_APPWRITE_PROJECT_NAME="Luz para Vida"

# Database (ID da tabela/database no console)
EXPO_PUBLIC_APPWRITE_DATABASE_ID=luz_para_vida_db

# Collections (Table IDs – devem coincidir com o Appwrite)
EXPO_PUBLIC_APPWRITE_COLLECTION_USUARIOS=usuarios
EXPO_PUBLIC_APPWRITE_COLLECTION_CELULAS=celulas
EXPO_PUBLIC_APPWRITE_COLLECTION_MEMBROS=membros
EXPO_PUBLIC_APPWRITE_COLLECTION_RELATORIOS=reuniao


# Storage: bucket para fotos de perfil (criar no Appwrite → Storage; ID do bucket)
EXPO_PUBLIC_APPWRITE_BUCKET_AVATARES=imagens
