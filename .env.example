# Copie para `.env` na raiz do projeto e preencha com os IDs do Console Appwrite.
# Reinicie o Metro após alterar: npx expo start -c
#
# Nomes das tables: ver docs/collectiosn.md — `usuarios`, `celulas`, `reuniao`, `visitante`.
# Os vínculos de pessoas à célula ficam no array `membros[]` do documento `celulas` (IDs do Auth),
# não existe collection separada `membros`.

# --- API Appwrite ---
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=

# Opcional (nome legível; não é lido pelo SDK em src/lib/appwrite/config.js)
EXPO_PUBLIC_APPWRITE_PROJECT_NAME="Luz para Vida"

# --- Database (Tables) ---
EXPO_PUBLIC_APPWRITE_DATABASE_ID=

# --- Collections (Table IDs) ---
EXPO_PUBLIC_APPWRITE_COLLECTION_USUARIOS=usuarios
EXPO_PUBLIC_APPWRITE_COLLECTION_CELULAS=celulas

# Collection `reuniao` (documentos de reunião).
EXPO_PUBLIC_APPWRITE_COLLECTION_REUNIAO=reuniao

# Collection `visitante` (visitantes vinculados a reunião).
EXPO_PUBLIC_APPWRITE_COLLECTION_VISITANTE=visitante

# Legado (opcional): se ainda usar nomes antigos no .env, o config aceita:
# EXPO_PUBLIC_APPWRITE_COLLECTION_RELATORIOS=
# EXPO_PUBLIC_APPWRITE_COLLECTION_VISITANTES=

# --- Storage ---
EXPO_PUBLIC_APPWRITE_BUCKET_AVATARES=
